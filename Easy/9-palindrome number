class Solution {
public:
    bool isPalindrome(int x) {
        int j,i;
        string strNum = to_string(x);
        for(j=0;strNum[j]!='\0';j++)
        {}
        for(i=0;strNum[i]!='\0';i++)
        {
            j--;
            if(!(strNum[i]==strNum[j]))
            break;
        }
        if(strNum[i]=='\0')
        return 1;
        return 0;
    }
};
