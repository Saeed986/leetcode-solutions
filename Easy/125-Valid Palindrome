class Solution {
public:
    bool isPalindrome(string s) {
        string temp="";
        int i,count=0;
        for(i=0;s[i]!='\0';i++)
        {
            if((s[i]>='A' && s[i]<='Z') || (s[i]>='a' && s[i]<='z') ||
            (s[i] >= '0' && s[i] <= '9'))
             temp.push_back(tolower(s[i]));
        }
        int j=0;
        i = temp.length() - 1;
        while(j<i)
        {
            if(temp[i]==temp[j])
            {
                j++;
                i--;
            }
            else
            return 0;
        }
        return 1;
    }
};
