class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int i,k=1;
        int length=nums.size();
        if(nums.empty()) 
        return 0;
        for(i=1;i<length;i++)
        {
            if(nums[i-1]!=nums[i])
            {
                nums[k]=nums[i];
                k++;
            }
        }
        return k;
    }
};
