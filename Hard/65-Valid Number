class Solution {
public:
    bool isNumber(string s) {
        bool isDigit = false;
        bool isE = false;
        bool isDot = false;
        int i;
        for (i = 0; s[i] != '\0'; i++) 
        {
            if (!((s[i] >= '0' && s[i] <= '9') || s[i] == 'E' || s[i] == 'e' || s[i] == '.' || s[i] == '+' || s[i] == '-')) {
                return 0;
            }

            if (s[i] == '+' || s[i] == '-') 
            {
                if (i > 0 && s[i - 1] != 'e' && s[i - 1] != 'E') 
                {
                    return 0;
                }
            }
            else if (s[i] == '.') 
            {
                if (isDot || isE) 
                {
                    return 0;
                }
                isDot = true;
            }
            else if (s[i] == 'e' || s[i] == 'E') {
                if (isE || !isDigit) 
                {
                    return 0;
                }
                isE = true;
                isDigit = false;
            }
            else if (s[i] >= '0' && s[i] <= '9') {
                isDigit = true;
            }
        }
        return isDigit;
    }
};
